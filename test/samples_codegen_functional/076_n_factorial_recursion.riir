fn factorial(mut n_0: i32) -> i32 {
    'entry: {
        %0: bool = @n_0 == 1;
        => if %0 { 'if_true_5_4 } else { 'if_false_5_4 };
    }
    'if_true_5_4: {
        return @n_0;
    }
    'if_false_5_4: {
        %1: i32 = @n_0 - 1;
        %2: i32 = @factorial(%1);
        %3: i32 = @n_0 * %2;
        return %3;
    }
}

fn main() -> i32 {
    let mut n_1: i32;
    let mut result_0: i32;
    'entry: {
        @n_1: i32 = 0;
        @result_0: i32 = 0;
        %0: i32 = @get_int();
        @n_1: i32 = %0;
        %1: bool = @n_1 > 1;
        => if %1 { 'if_true_15_4 } else { 'if_false_15_4 };
    }
    'if_true_15_4: {
        %2: i32 = @factorial(@n_1);
        @result_0: i32 = %2;
        => 'if_exit_15_4;
    }
    'if_exit_15_4: {
        %3: () = @print_int(@result_0);
        return 0;
    }
    'if_false_15_4: {
        @result_0: i32 = 1;
        => 'if_exit_15_4;
    }
}
