fn climbStairs(mut n_0: i32) -> i32 {
    let mut dp_0: [i32; 10];
    let mut i_0: i32;
    'entry: {
        %0: bool = @n_0 < 4;
        => if %0 { 'if_true_2_4 } else { 'if_exit_2_4 };
    }
    'if_true_2_4: {
        return @n_0;
    }
    'if_exit_2_4: {
        @dp_0: [i32; 10] = {0};
        %1: &mut i32 = &mut @dp_0[0];
        %2: () = %1 <- 0;
        %3: &mut i32 = &mut @dp_0[1];
        %4: () = %3 <- 1;
        %5: &mut i32 = &mut @dp_0[2];
        %6: () = %5 <- 2;
        @i_0: i32 = 0;
        @i_0: i32 = 3;
        => 'while_cond_10_4;
    }
    'while_cond_10_4: {
        %7: i32 = @n_0 + 1;
        %8: bool = @i_0 < %7;
        => if %8 { 'while_body_10_4 } else { 'while_exit_10_4 };
    }
    'while_body_10_4: {
        %9: i32 = @i_0 - 1;
        %10: &i32 = & @dp_0[%9];
        %11: i32 = * %10;
        %12: i32 = @i_0 - 2;
        %13: &i32 = & @dp_0[%12];
        %14: i32 = * %13;
        %15: i32 = %11 + %14;
        %16: &mut i32 = &mut @dp_0[@i_0];
        %17: () = %16 <- %15;
        %18: i32 = @i_0 + 1;
        @i_0: i32 = %18;
        => 'while_cond_10_4;
    }
    'while_exit_10_4: {
        %19: &i32 = & @dp_0[@n_0];
        %20: i32 = * %19;
        return %20;
    }
}

fn main() -> i32 {
    let mut res_0: i32;
    let mut n_1: i32;
    'entry: {
        @res_0: i32 = 0;
        @n_1: i32 = 0;
        @n_1: i32 = 5;
        %0: i32 = @climbStairs(@n_1);
        @res_0: i32 = %0;
        return @res_0;
    }
}
