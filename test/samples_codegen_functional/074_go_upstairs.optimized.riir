fn climbStairs(n_0: i32) -> i32 {
    let ref dp_0: [i32; 10];
    'entry: {
        %0: bool = @n_0 < 4;
        => if %0 { 'if_true_2_4 } else { 'if_exit_2_4 };
    }
    'if_true_2_4: {
        return @n_0;
    }
    'if_exit_2_4: {
        @dp_0 <- {0};
        %1: &mut i32 = &mut @dp_0[0];
        %1 <- 0;
        %2: &mut i32 = &mut @dp_0[1];
        %2 <- 1;
        %3: &mut i32 = &mut @dp_0[2];
        %3 <- 2;
        => 'while_cond_10_4;
    }
    'while_cond_10_4: {
        %17: i32 = phi('while_body_10_4: %14, 'if_exit_2_4: 3);
        %4: i32 = @n_0 + 1;
        %5: bool = %17 < %4;
        => if %5 { 'while_body_10_4 } else { 'while_exit_10_4 };
    }
    'while_body_10_4: {
        %6: i32 = %17 - 1;
        %7: &i32 = & @dp_0[%6];
        %8: i32 = * %7;
        %9: i32 = %17 - 2;
        %10: &i32 = & @dp_0[%9];
        %11: i32 = * %10;
        %12: i32 = %8 + %11;
        %13: &mut i32 = &mut @dp_0[%17];
        %13 <- %12;
        %14: i32 = %17 + 1;
        => 'while_cond_10_4;
    }
    'while_exit_10_4: {
        %15: &i32 = & @dp_0[@n_0];
        %16: i32 = * %15;
        return %16;
    }
}

fn main() -> i32 {
    'entry: {
        %0: i32 = @climbStairs(5);
        return %0;
    }
}
