fn climbStairs(n_0: i32) -> i32 {
    'entry: {
        %0: bool = @n_0 < 4;
        branch %0 ? 'if_true_2_4 : 'if_exit_2_4;
    }
    'if_true_2_4: {
        return @n_0;
    }
    'if_exit_2_4: {
        %21: [i32; 10] = {0};
        %1: &mut i32 = &mut %21[0];
        %2: () = %store(%1, 0);
        %3: &mut i32 = &mut %21[1];
        %4: () = %store(%3, 1);
        %5: &mut i32 = &mut %21[2];
        %6: () = %store(%5, 2);
        jump 'while_cond_10_4;
    }
    'while_cond_10_4: {
        %25: i32 = %phi('while_body_10_4: %18, 'if_exit_2_4: 3);
        %7: i32 = @n_0 + 1;
        %8: bool = %25 < %7;
        branch %8 ? 'while_body_10_4 : 'while_exit_10_4;
    }
    'while_body_10_4: {
        %9: i32 = %25 - 1;
        %10: &i32 = & %21[%9];
        %11: i32 = * %10;
        %12: i32 = %25 - 2;
        %13: &i32 = & %21[%12];
        %14: i32 = * %13;
        %15: i32 = %11 + %14;
        %16: &mut i32 = &mut %21[%25];
        %17: () = %store(%16, %15);
        %18: i32 = %25 + 1;
        jump 'while_cond_10_4;
    }
    'while_exit_10_4: {
        %19: &i32 = & %21[@n_0];
        %20: i32 = * %19;
        return %20;
    }
}

fn main() -> i32 {
    'entry: {
        %0: i32 = @climbStairs(5);
        return %0;
    }
}
