fn main() -> i32 {
    let ref a_0: [i32; 100];
    let ref x_0: [i32; 4];
    let ref b_0: [i32; 100];
    'entry: {
        @a_0 <- {1, 2, 3};
        @x_0 <- {0, 1, 2, 3};
        @b_0 <- {0};
        %0: &i32 = & @b_0[99];
        %1: i32 = * (&i32)%0;
        %2: &i32 = & @a_0[2];
        %3: i32 = * (&i32)%2;
        %4: i32 = %1 + %3;
        %5: &i32 = & @x_0[3];
        %6: i32 = * (&i32)%5;
        %7: i32 = %4 + %6;
        return %7;
    }
}
