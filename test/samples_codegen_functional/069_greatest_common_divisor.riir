fn fun(mut m_0: i32, mut n_0: i32) -> i32 {
    let mut rem_0: i32;
    'entry: {
        @rem_0: i32 = 0;
        => 'while_cond_3_1;
    }
    'while_cond_3_1: {
        %0: bool = @n_0 > 0;
        => if %0 { 'while_body_3_1 } else { 'while_exit_3_1 };
    }
    'while_body_3_1: {
        %1: i32 = @m_0 % @n_0;
        @rem_0: i32 = %1;
        @m_0: i32 = @n_0;
        @n_0: i32 = @rem_0;
        => 'while_cond_3_1;
    }
    'while_exit_3_1: {
        return @m_0;
    }
}

fn main() -> i32 {
    let mut n_1: i32;
    let mut m_1: i32;
    let mut num_0: i32;
