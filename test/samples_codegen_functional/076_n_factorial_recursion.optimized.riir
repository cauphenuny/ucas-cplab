fn factorial(n_0: i32) -> i32 {
    'entry: {
        %0: bool = @n_0 == 1;
        branch %0 ? 'if_true_5_4 : 'if_false_5_4;
    }
    'if_true_5_4: {
        return @n_0;
    }
    'if_false_5_4: {
        %1: i32 = @n_0 - 1;
        %2: i32 = @factorial(%1);
        %3: i32 = @n_0 * %2;
        return %3;
    }
}

fn main() -> i32 {
    'entry: {
        %0: i32 = @get_int();
        %1: bool = %0 > 1;
        branch %1 ? 'if_true_15_4 : 'if_exit_15_4;
    }
    'if_true_15_4: {
        %2: i32 = @factorial(%0);
        jump 'if_exit_15_4;
    }
    'if_exit_15_4: {
        %9: i32 = %phi('if_true_15_4: %2, 'entry: 1);
        %3: () = @print_int(%9);
        return 0;
    }
}
